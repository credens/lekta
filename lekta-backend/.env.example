PORT=3300
DATABASE_URL=postgresql://lekta:CHANGE_ME@localhost:5432/lekta_backend

# App/backend auth. Generate strong random values and keep them out of the app repo.
JWT_SECRET=CHANGE_ME_RANDOM_64_CHARS
APP_BOOTSTRAP_TOKEN=CHANGE_ME_RANDOM_BOOTSTRAP_TOKEN
APP_ACCESS_TOKEN_SECONDS=900
APP_REFRESH_TOKEN_DAYS=30

# AES-256-GCM key for Mercado Pago tokens. Use 32 random bytes in base64 or 64 hex chars.
TOKEN_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_BASE64_OR_64_HEX

# Basic abuse protection.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Set true in production behind nginx with X-Forwarded-Proto=https.
ENFORCE_HTTPS=false

# Mercado Pago OAuth app credentials. Keep these only on the backend.
MP_CLIENT_ID=CHANGE_ME
MP_CLIENT_SECRET=CHANGE_ME
MP_REDIRECT_URI=warehouseapp://auth

# Public HTTPS base URL used to build webhook URLs.
# In local development use an HTTPS tunnel such as ngrok/cloudflared.
PUBLIC_BASE_URL=https://api.example.com

# Optional override. If omitted, defaults to PUBLIC_BASE_URL/api/webhooks/mercadopago
MP_NOTIFICATION_URL=
