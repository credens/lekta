PORT=3300
DATABASE_URL=postgresql://lekta:CHANGE_ME@localhost:5432/lekta_backend

# Mercado Pago OAuth app credentials. Keep these only on the backend.
MP_CLIENT_ID=CHANGE_ME
MP_CLIENT_SECRET=CHANGE_ME
MP_REDIRECT_URI=warehouseapp://auth

# Public HTTPS base URL used to build webhook URLs.
# In local development use an HTTPS tunnel such as ngrok/cloudflared.
PUBLIC_BASE_URL=https://api.example.com

# Optional override. If omitted, defaults to PUBLIC_BASE_URL/api/webhooks/mercadopago
MP_NOTIFICATION_URL=
